{
  "$defs": {
    "AssignCell": {
      "additionalProperties": false,
      "description": "Tentatively select one anchor row for an item variable.",
      "properties": {
        "kind": {
          "const": "assign_cell",
          "default": "assign_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignCell",
      "type": "object"
    },
    "AssignmentAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "assignment",
          "default": "assignment",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignmentAtom",
      "type": "object"
    },
    "AttemptId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "CheckCompletion": {
      "additionalProperties": false,
      "description": "Ask the independent final checker to evaluate the active marks.",
      "properties": {
        "kind": {
          "const": "check_completion",
          "default": "check_completion",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "CheckCompletion",
      "type": "object"
    },
    "CheckpointName": {
      "maxLength": 80,
      "minLength": 1,
      "type": "string"
    },
    "ClearCell": {
      "additionalProperties": false,
      "description": "Clear a tentative selection or exclusion from one cell.",
      "properties": {
        "kind": {
          "const": "clear_cell",
          "default": "clear_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ClearCell",
      "type": "object"
    },
    "CreateCheckpoint": {
      "additionalProperties": false,
      "description": "Name the current retained history position.",
      "properties": {
        "kind": {
          "const": "create_checkpoint",
          "default": "create_checkpoint",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/CheckpointName"
        }
      },
      "required": [
        "name"
      ],
      "title": "CreateCheckpoint",
      "type": "object"
    },
    "EventId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "ExcludeCell": {
      "additionalProperties": false,
      "description": "Tentatively exclude one anchor row from an item variable.",
      "properties": {
        "kind": {
          "const": "exclude_cell",
          "default": "exclude_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ExcludeCell",
      "type": "object"
    },
    "ExclusionAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "exclusion",
          "default": "exclusion",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ExclusionAtom",
      "type": "object"
    },
    "Identifier": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "PauseSession": {
      "additionalProperties": false,
      "description": "Pause interaction without changing the current history position.",
      "properties": {
        "kind": {
          "const": "pause_session",
          "default": "pause_session",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "PauseSession",
      "type": "object"
    },
    "PlayAction": {
      "discriminator": {
        "mapping": {
          "assign_cell": "#/$defs/AssignCell",
          "check_completion": "#/$defs/CheckCompletion",
          "clear_cell": "#/$defs/ClearCell",
          "create_checkpoint": "#/$defs/CreateCheckpoint",
          "exclude_cell": "#/$defs/ExcludeCell",
          "pause_session": "#/$defs/PauseSession",
          "redo_move": "#/$defs/RedoMove",
          "restore_checkpoint": "#/$defs/RestoreCheckpoint",
          "resume_session": "#/$defs/ResumeSession",
          "undo_move": "#/$defs/UndoMove",
          "validate_progress": "#/$defs/ValidateProgress"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/AssignCell"
        },
        {
          "$ref": "#/$defs/ExcludeCell"
        },
        {
          "$ref": "#/$defs/ClearCell"
        },
        {
          "$ref": "#/$defs/UndoMove"
        },
        {
          "$ref": "#/$defs/RedoMove"
        },
        {
          "$ref": "#/$defs/CheckCompletion"
        },
        {
          "$ref": "#/$defs/ValidateProgress"
        },
        {
          "$ref": "#/$defs/PauseSession"
        },
        {
          "$ref": "#/$defs/ResumeSession"
        },
        {
          "$ref": "#/$defs/CreateCheckpoint"
        },
        {
          "$ref": "#/$defs/RestoreCheckpoint"
        }
      ]
    },
    "PlayCheckpoint": {
      "additionalProperties": false,
      "description": "A named reference to one retained move cursor and captured state.",
      "properties": {
        "captured_sequence_no": {
          "minimum": 0,
          "title": "Captured Sequence No",
          "type": "integer"
        },
        "captured_state_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "checkpoint_id": {
          "$ref": "#/$defs/EventId"
        },
        "move_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "name": {
          "$ref": "#/$defs/CheckpointName"
        }
      },
      "required": [
        "checkpoint_id",
        "name",
        "captured_sequence_no",
        "captured_state_hash"
      ],
      "title": "PlayCheckpoint",
      "type": "object"
    },
    "PlayConflict": {
      "additionalProperties": false,
      "description": "Presentation-safe structural conflict in tentative play marks.",
      "properties": {
        "code": {
          "enum": [
            "duplicate_row",
            "no_candidate"
          ],
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "references": {
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "title": "References",
          "type": "array"
        }
      },
      "required": [
        "code",
        "references",
        "message"
      ],
      "title": "PlayConflict",
      "type": "object"
    },
    "PlayEvent": {
      "additionalProperties": false,
      "description": "One retained interaction outcome in a tamper-evident attempt stream.",
      "properties": {
        "accepted": {
          "title": "Accepted",
          "type": "boolean"
        },
        "action": {
          "$ref": "#/$defs/PlayAction"
        },
        "code": {
          "title": "Code",
          "type": "string"
        },
        "event_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "event_id": {
          "$ref": "#/$defs/EventId"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "parent_move_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "previous_event_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "resulting_move_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resulting_state_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "schema_version": {
          "const": "1.1.0",
          "default": "1.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "sequence_no": {
          "minimum": 0,
          "title": "Sequence No",
          "type": "integer"
        }
      },
      "required": [
        "event_id",
        "sequence_no",
        "action",
        "accepted",
        "code",
        "message",
        "resulting_state_hash",
        "previous_event_hash",
        "event_hash"
      ],
      "title": "PlayEvent",
      "type": "object"
    },
    "PlaySessionStatus": {
      "description": "Terminal status of a presentation-neutral play attempt.",
      "enum": [
        "active",
        "paused",
        "completed"
      ],
      "title": "PlaySessionStatus",
      "type": "string"
    },
    "PlayValidationMode": {
      "description": "When structural progress conflicts are disclosed to the player.",
      "enum": [
        "strict",
        "soft",
        "deferred",
        "exam"
      ],
      "title": "PlayValidationMode",
      "type": "string"
    },
    "PuzzleRevisionId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "RedoMove": {
      "additionalProperties": false,
      "description": "Move the active history cursor to one retained direct child.",
      "properties": {
        "kind": {
          "const": "redo_move",
          "default": "redo_move",
          "title": "Kind",
          "type": "string"
        },
        "target_move_id": {
          "$ref": "#/$defs/EventId"
        }
      },
      "required": [
        "target_move_id"
      ],
      "title": "RedoMove",
      "type": "object"
    },
    "RestoreCheckpoint": {
      "additionalProperties": false,
      "description": "Move the active cursor to a retained named checkpoint.",
      "properties": {
        "checkpoint_id": {
          "$ref": "#/$defs/EventId"
        },
        "kind": {
          "const": "restore_checkpoint",
          "default": "restore_checkpoint",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "checkpoint_id"
      ],
      "title": "RestoreCheckpoint",
      "type": "object"
    },
    "ResumeSession": {
      "additionalProperties": false,
      "description": "Resume a paused interaction session.",
      "properties": {
        "kind": {
          "const": "resume_session",
          "default": "resume_session",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "ResumeSession",
      "type": "object"
    },
    "Sha256Digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "UndoMove": {
      "additionalProperties": false,
      "description": "Move the active history cursor to the parent of its current move.",
      "properties": {
        "kind": {
          "const": "undo_move",
          "default": "undo_move",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "UndoMove",
      "type": "object"
    },
    "ValidateProgress": {
      "additionalProperties": false,
      "description": "Request structural progress validation when the mode permits it.",
      "properties": {
        "kind": {
          "const": "validate_progress",
          "default": "validate_progress",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "ValidateProgress",
      "type": "object"
    },
    "ValueId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "VariableId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    }
  },
  "$id": "urn:deductra:schema:logic-grid-play-session:1",
  "additionalProperties": false,
  "description": "Current immutable marks plus the complete retained interaction history.",
  "properties": {
    "active_move_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/EventId"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "assignments": {
      "items": {
        "$ref": "#/$defs/AssignmentAtom"
      },
      "title": "Assignments",
      "type": "array"
    },
    "attempt_id": {
      "$ref": "#/$defs/AttemptId"
    },
    "checkpoints": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PlayCheckpoint"
      },
      "title": "Checkpoints",
      "type": "array"
    },
    "conflicts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PlayConflict"
      },
      "title": "Conflicts",
      "type": "array"
    },
    "events": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PlayEvent"
      },
      "maxItems": 10000,
      "title": "Events",
      "type": "array"
    },
    "exclusions": {
      "items": {
        "$ref": "#/$defs/ExclusionAtom"
      },
      "title": "Exclusions",
      "type": "array"
    },
    "puzzle_revision_id": {
      "$ref": "#/$defs/PuzzleRevisionId"
    },
    "schema_version": {
      "const": "1.1.0",
      "default": "1.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_hash": {
      "$ref": "#/$defs/Sha256Digest"
    },
    "state_hash": {
      "$ref": "#/$defs/Sha256Digest"
    },
    "status": {
      "$ref": "#/$defs/PlaySessionStatus"
    },
    "validation_mode": {
      "$ref": "#/$defs/PlayValidationMode",
      "default": "soft"
    }
  },
  "required": [
    "attempt_id",
    "puzzle_revision_id",
    "status",
    "assignments",
    "exclusions",
    "state_hash",
    "session_hash"
  ],
  "title": "Deductra Logic Grid Play Session v1",
  "type": "object"
}
