{
  "$defs": {
    "ArtifactId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "ArtifactRecorded": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/ArtifactId"
        },
        "artifact_kind": {
          "enum": [
            "report",
            "image",
            "export",
            "trace",
            "hypergraph",
            "other"
          ],
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "evidence_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "kind": {
          "const": "artifact_recorded",
          "default": "artifact_recorded",
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "provenance_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Provenance Ids",
          "type": "array"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        }
      },
      "required": [
        "artifact_id",
        "puzzle_revision_id",
        "artifact_kind",
        "media_type",
        "content_hash"
      ],
      "title": "ArtifactRecorded",
      "type": "object"
    },
    "ArtifactRemoved": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/ArtifactId"
        },
        "kind": {
          "const": "artifact_removed",
          "default": "artifact_removed",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "reason"
      ],
      "title": "ArtifactRemoved",
      "type": "object"
    },
    "ArtifactSuperseded": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/ArtifactId"
        },
        "kind": {
          "const": "artifact_superseded",
          "default": "artifact_superseded",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "replacement_artifact_id": {
          "$ref": "#/$defs/ArtifactId"
        }
      },
      "required": [
        "artifact_id",
        "replacement_artifact_id"
      ],
      "title": "ArtifactSuperseded",
      "type": "object"
    },
    "AssignCell": {
      "additionalProperties": false,
      "description": "Tentatively select one anchor row for an item variable.",
      "properties": {
        "kind": {
          "const": "assign_cell",
          "default": "assign_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignCell",
      "type": "object"
    },
    "AssignmentAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "assignment",
          "default": "assignment",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignmentAtom",
      "type": "object"
    },
    "AttemptAbandoned": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "kind": {
          "const": "attempt_abandoned",
          "default": "attempt_abandoned",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "attempt_id"
      ],
      "title": "AttemptAbandoned",
      "type": "object"
    },
    "AttemptCompleted": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "kind": {
          "const": "attempt_completed",
          "default": "attempt_completed",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "attempt_id"
      ],
      "title": "AttemptCompleted",
      "type": "object"
    },
    "AttemptId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "AttemptProjection": {
      "additionalProperties": false,
      "description": "One attempt view derived entirely from its validated event stream.",
      "properties": {
        "accepted_moves": {
          "minimum": 0,
          "title": "Accepted Moves",
          "type": "integer"
        },
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "explanations_viewed": {
          "minimum": 0,
          "title": "Explanations Viewed",
          "type": "integer"
        },
        "hints_revealed": {
          "minimum": 0,
          "title": "Hints Revealed",
          "type": "integer"
        },
        "projection_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        },
        "rejected_moves": {
          "minimum": 0,
          "title": "Rejected Moves",
          "type": "integer"
        },
        "replays_viewed": {
          "minimum": 0,
          "title": "Replays Viewed",
          "type": "integer"
        },
        "rule_evidence": {
          "items": {
            "$ref": "#/$defs/RuleAttemptEvidence"
          },
          "title": "Rule Evidence",
          "type": "array"
        },
        "self_assessment": {
          "anyOf": [
            {
              "maximum": 5,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Self Assessment"
        },
        "source_event_ids": {
          "items": {
            "$ref": "#/$defs/EventId"
          },
          "title": "Source Event Ids",
          "type": "array"
        },
        "source_head_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "status": {
          "$ref": "#/$defs/AttemptStatus"
        },
        "stream_id": {
          "$ref": "#/$defs/ProjectionStreamId"
        },
        "total_moves": {
          "minimum": 0,
          "title": "Total Moves",
          "type": "integer"
        },
        "user_id": {
          "$ref": "#/$defs/UserId"
        }
      },
      "required": [
        "attempt_id",
        "user_id",
        "puzzle_revision_id",
        "stream_id",
        "status",
        "total_moves",
        "accepted_moves",
        "rejected_moves",
        "hints_revealed",
        "explanations_viewed",
        "replays_viewed",
        "rule_evidence",
        "source_event_ids",
        "source_head_hash",
        "projection_hash"
      ],
      "title": "AttemptProjection",
      "type": "object"
    },
    "AttemptStarted": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "kind": {
          "const": "attempt_started",
          "default": "attempt_started",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        },
        "user_id": {
          "$ref": "#/$defs/UserId"
        }
      },
      "required": [
        "attempt_id",
        "user_id",
        "puzzle_revision_id"
      ],
      "title": "AttemptStarted",
      "type": "object"
    },
    "AttemptStatus": {
      "enum": [
        "active",
        "completed",
        "abandoned"
      ],
      "title": "AttemptStatus",
      "type": "string"
    },
    "CandidateId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "CheckCompletion": {
      "additionalProperties": false,
      "description": "Ask the independent final checker to evaluate the active marks.",
      "properties": {
        "kind": {
          "const": "check_completion",
          "default": "check_completion",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "CheckCompletion",
      "type": "object"
    },
    "CheckpointName": {
      "maxLength": 80,
      "minLength": 1,
      "type": "string"
    },
    "ClearCell": {
      "additionalProperties": false,
      "description": "Clear a tentative selection or exclusion from one cell.",
      "properties": {
        "kind": {
          "const": "clear_cell",
          "default": "clear_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ClearCell",
      "type": "object"
    },
    "CreateCheckpoint": {
      "additionalProperties": false,
      "description": "Name the current retained history position.",
      "properties": {
        "kind": {
          "const": "create_checkpoint",
          "default": "create_checkpoint",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/CheckpointName"
        }
      },
      "required": [
        "name"
      ],
      "title": "CreateCheckpoint",
      "type": "object"
    },
    "EventId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "EventSchemaVersion": {
      "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    },
    "ExcludeCell": {
      "additionalProperties": false,
      "description": "Tentatively exclude one anchor row from an item variable.",
      "properties": {
        "kind": {
          "const": "exclude_cell",
          "default": "exclude_cell",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ExcludeCell",
      "type": "object"
    },
    "ExclusionAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "exclusion",
          "default": "exclusion",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ExclusionAtom",
      "type": "object"
    },
    "HintRevealed": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "kind": {
          "const": "hint_revealed",
          "default": "hint_revealed",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "rule_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuleId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "attempt_id"
      ],
      "title": "HintRevealed",
      "type": "object"
    },
    "Identifier": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "JsonValue": {},
    "LogicGridAttemptEvidence": {
      "additionalProperties": false,
      "description": "Disposable descriptive view rebuilt exactly from one play session.",
      "properties": {
        "accepted_actions": {
          "title": "Accepted Actions",
          "type": "integer"
        },
        "action_evidence": {
          "items": {
            "$ref": "#/$defs/PlayActionEvidence"
          },
          "title": "Action Evidence",
          "type": "array"
        },
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "projection_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "puzzle_revision_id": {
          "title": "Puzzle Revision Id",
          "type": "string"
        },
        "rejected_actions": {
          "title": "Rejected Actions",
          "type": "integer"
        },
        "source_event_ids": {
          "items": {
            "$ref": "#/$defs/EventId"
          },
          "title": "Source Event Ids",
          "type": "array"
        },
        "source_head_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "source_session_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "status": {
          "$ref": "#/$defs/PlaySessionStatus"
        },
        "total_actions": {
          "title": "Total Actions",
          "type": "integer"
        },
        "user_id": {
          "$ref": "#/$defs/UserId"
        }
      },
      "required": [
        "attempt_id",
        "user_id",
        "puzzle_revision_id",
        "status",
        "total_actions",
        "accepted_actions",
        "rejected_actions",
        "action_evidence",
        "source_event_ids",
        "source_head_hash",
        "source_session_hash",
        "projection_hash"
      ],
      "title": "LogicGridAttemptEvidence",
      "type": "object"
    },
    "LogicGridPlaySession": {
      "additionalProperties": false,
      "description": "Current immutable marks plus the complete retained interaction history.",
      "properties": {
        "active_move_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "assignments": {
          "items": {
            "$ref": "#/$defs/AssignmentAtom"
          },
          "title": "Assignments",
          "type": "array"
        },
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "checkpoints": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PlayCheckpoint"
          },
          "title": "Checkpoints",
          "type": "array"
        },
        "conflicts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PlayConflict"
          },
          "title": "Conflicts",
          "type": "array"
        },
        "events": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PlayEvent"
          },
          "maxItems": 10000,
          "title": "Events",
          "type": "array"
        },
        "exclusions": {
          "items": {
            "$ref": "#/$defs/ExclusionAtom"
          },
          "title": "Exclusions",
          "type": "array"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        },
        "schema_version": {
          "const": "1.1.0",
          "default": "1.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "session_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "state_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "status": {
          "$ref": "#/$defs/PlaySessionStatus"
        },
        "validation_mode": {
          "$ref": "#/$defs/PlayValidationMode",
          "default": "soft"
        }
      },
      "required": [
        "attempt_id",
        "puzzle_revision_id",
        "status",
        "assignments",
        "exclusions",
        "state_hash",
        "session_hash"
      ],
      "title": "LogicGridPlaySession",
      "type": "object"
    },
    "MoveEvaluated": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/AttemptId"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "kind": {
          "const": "move_evaluated",
          "default": "move_evaluated",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "outcome": {
          "enum": [
            "accepted",
            "rejected"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "rule_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuleId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "attempt_id",
        "outcome",
        "duration_ms"
      ],
      "title": "MoveEvaluated",
      "type": "object"
    },
    "NoveltyEntryRecorded": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/CandidateId"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "fingerprints": {
          "$ref": "#/$defs/PuzzleFingerprints"
        },
        "kind": {
          "const": "novelty_entry_recorded",
          "default": "novelty_entry_recorded",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "puzzle_id": {
          "$ref": "#/$defs/PuzzleId"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        }
      },
      "required": [
        "puzzle_id",
        "puzzle_revision_id",
        "candidate_id",
        "fingerprints",
        "evidence_ids"
      ],
      "title": "NoveltyEntryRecorded",
      "type": "object"
    },
    "NoveltyEntryRemoved": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "novelty_entry_removed",
          "default": "novelty_entry_removed",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "puzzle_revision_id",
        "reason"
      ],
      "title": "NoveltyEntryRemoved",
      "type": "object"
    },
    "ObservedPlayEvent": {
      "additionalProperties": false,
      "description": "One play event paired with its local observation time.",
      "properties": {
        "event": {
          "$ref": "#/$defs/PlayEvent"
        },
        "observation_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        }
      },
      "required": [
        "event",
        "occurred_at",
        "observation_hash"
      ],
      "title": "ObservedPlayEvent",
      "type": "object"
    },
    "PauseSession": {
      "additionalProperties": false,
      "description": "Pause interaction without changing the current history position.",
      "properties": {
        "kind": {
          "const": "pause_session",
          "default": "pause_session",
          "title": "Kind",
          "type": "string"
        }
      },
      "title": "PauseSession",
      "type": "object"
    },
    "PlayAction": {
      "discriminator": {
        "mapping": {
          "assign_cell": "#/$defs/AssignCell",
          "check_completion": "#/$defs/CheckCompletion",
          "clear_cell": "#/$defs/ClearCell",
          "create_checkpoint": "#/$defs/CreateCheckpoint",
          "exclude_cell": "#/$defs/ExcludeCell",
          "pause_session": "#/$defs/PauseSession",
          "redo_move": "#/$defs/RedoMove",
          "restore_checkpoint": "#/$defs/RestoreCheckpoint",
          "resume_session": "#/$defs/ResumeSession",
          "undo_move": "#/$defs/UndoMove",
          "validate_progress": "#/$defs/ValidateProgress"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/AssignCell"
        },
        {
          "$ref": "#/$defs/ExcludeCell"
        },
        {
          "$ref": "#/$defs/ClearCell"
        },
        {
          "$ref": "#/$defs/UndoMove"
        },
        {
          "$ref": "#/$defs/RedoMove"
        },
        {
          "$ref": "#/$defs/CheckCompletion"
        },
        {
          "$ref": "#/$defs/ValidateProgress"
        },
        {
          "$ref": "#/$defs/PauseSession"
        },
        {
          "$ref": "#/$defs/ResumeSession"
        },
        {
          "$ref": "#/$defs/CreateCheckpoint"
        },
        {
          "$ref": "#/$defs/RestoreCheckpoint"
        }
      ]
    },
    "PlayActionEvidence": {
      "additionalProperties": false,
      "description": "Descriptive action counts without correctness or mastery meaning.",
      "properties": {
        "accepted_actions": {
          "title": "Accepted Actions",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/PlayActionKind"
        },
        "rejected_actions": {
          "title": "Rejected Actions",
          "type": "integer"
        },
        "source_event_ids": {
          "items": {
            "$ref": "#/$defs/EventId"
          },
          "title": "Source Event Ids",
          "type": "array"
        }
      },
      "required": [
        "kind",
        "accepted_actions",
        "rejected_actions",
        "source_event_ids"
      ],
      "title": "PlayActionEvidence",
      "type": "object"
