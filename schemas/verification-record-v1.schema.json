{
  "$defs": {
    "AggregateAtom": {
      "additionalProperties": false,
      "properties": {
        "comparator": {
          "enum": [
            "eq",
            "ne",
            "lt",
            "le",
            "gt",
            "ge"
          ],
          "title": "Comparator",
          "type": "string"
        },
        "kind": {
          "const": "aggregate",
          "default": "aggregate",
          "title": "Kind",
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "title": "Members",
          "type": "array"
        },
        "operator": {
          "enum": [
            "sum",
            "count",
            "min",
            "max",
            "parity"
          ],
          "title": "Operator",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "integer"
        }
      },
      "required": [
        "operator",
        "members",
        "comparator",
        "target"
      ],
      "title": "AggregateAtom",
      "type": "object"
    },
    "AssignmentAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "assignment",
          "default": "assignment",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignmentAtom",
      "type": "object"
    },
    "AssignmentNegation": {
      "additionalProperties": false,
      "description": "Counter-assume that a claimed assignment is false.",
      "properties": {
        "kind": {
          "const": "assignment_negation",
          "default": "assignment_negation",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "AssignmentNegation",
      "type": "object"
    },
    "Atom": {
      "discriminator": {
        "mapping": {
          "aggregate": "#/$defs/AggregateAtom",
          "assignment": "#/$defs/AssignmentAtom",
          "exclusion": "#/$defs/ExclusionAtom",
          "relation": "#/$defs/RelationAtom",
          "truth": "#/$defs/TruthAtom"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/AssignmentAtom"
        },
        {
          "$ref": "#/$defs/ExclusionAtom"
        },
        {
          "$ref": "#/$defs/RelationAtom"
        },
        {
          "$ref": "#/$defs/AggregateAtom"
        },
        {
          "$ref": "#/$defs/TruthAtom"
        }
      ]
    },
    "BackendResult": {
      "enum": [
        "sat",
        "unsat",
        "unknown",
        "invalid"
      ],
      "type": "string"
    },
    "CertificateId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "EliminationNegation": {
      "additionalProperties": false,
      "description": "Counter-assume that a claimed eliminated value is possible.",
      "properties": {
        "kind": {
          "const": "elimination_negation",
          "default": "elimination_negation",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "EliminationNegation",
      "type": "object"
    },
    "ExclusionAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "exclusion",
          "default": "exclusion",
          "title": "Kind",
          "type": "string"
        },
        "value_id": {
          "$ref": "#/$defs/ValueId"
        },
        "variable_id": {
          "$ref": "#/$defs/VariableId"
        }
      },
      "required": [
        "variable_id",
        "value_id"
      ],
      "title": "ExclusionAtom",
      "type": "object"
    },
    "JsonValue": {},
    "NegatedClaim": {
      "discriminator": {
        "mapping": {
          "assignment_negation": "#/$defs/AssignmentNegation",
          "elimination_negation": "#/$defs/EliminationNegation"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/AssignmentNegation"
        },
        {
          "$ref": "#/$defs/EliminationNegation"
        }
      ]
    },
    "ObligationId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "ProofObligation": {
      "additionalProperties": false,
      "description": "One claim whose negation must be unsatisfiable in the named source state.",
      "properties": {
        "assumptions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Atom"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "claimed_conclusions": {
          "items": {
            "$ref": "#/$defs/Atom"
          },
          "title": "Claimed Conclusions",
          "type": "array"
        },
        "encoding_version": {
          "default": "1.0.0",
          "title": "Encoding Version",
          "type": "string"
        },
        "expected_result": {
          "const": "unsat",
          "default": "unsat",
          "title": "Expected Result",
          "type": "string"
        },
        "negated_claim": {
          "$ref": "#/$defs/NegatedClaim"
        },
        "obligation_id": {
          "$ref": "#/$defs/ObligationId"
        },
        "puzzle_revision_id": {
          "$ref": "#/$defs/PuzzleRevisionId"
        },
        "source_state_hash": {
          "$ref": "#/$defs/Sha256Digest"
        }
      },
      "required": [
        "obligation_id",
        "puzzle_revision_id",
        "source_state_hash",
        "claimed_conclusions",
        "negated_claim"
      ],
      "title": "ProofObligation",
      "type": "object"
    },
    "PuzzleRevisionId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "RelationAtom": {
      "additionalProperties": false,
      "properties": {
        "arguments": {
          "items": {
            "type": "string"
          },
          "title": "Arguments",
          "type": "array"
        },
        "kind": {
          "const": "relation",
          "default": "relation",
          "title": "Kind",
          "type": "string"
        },
        "relation": {
          "title": "Relation",
          "type": "string"
        }
      },
      "required": [
        "relation",
        "arguments"
      ],
      "title": "RelationAtom",
      "type": "object"
    },
    "Sha256Digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "TruthAtom": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "truth",
          "default": "truth",
          "title": "Kind",
          "type": "string"
        },
        "proposition_id": {
          "title": "Proposition Id",
          "type": "string"
        },
        "truth_value": {
          "title": "Truth Value",
          "type": "boolean"
        }
      },
      "required": [
        "proposition_id",
        "truth_value"
      ],
      "title": "TruthAtom",
      "type": "object"
    },
    "ValueId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "VariableId": {
      "maxLength": 255,
      "minLength": 1,
      "type": "string"
    },
    "VerificationCertificate": {
      "additionalProperties": false,
      "description": "Immutable result and provenance returned by one verification backend.",
      "properties": {
        "backend_id": {
          "title": "Backend Id",
          "type": "string"
        },
        "backend_version": {
          "title": "Backend Version",
          "type": "string"
        },
        "certificate_hash": {
          "$ref": "#/$defs/Sha256Digest"
        },
        "certificate_id": {
          "$ref": "#/$defs/CertificateId"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "encoding_version": {
          "title": "Encoding Version",
          "type": "string"
        },
        "model_snapshot": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Snapshot"
        },
        "obligation_id": {
          "$ref": "#/$defs/ObligationId"
        },
        "raw_artifact_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Digest"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "result": {
          "$ref": "#/$defs/BackendResult"
        },
        "unsat_core_refs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Unsat Core Refs",
          "type": "array"
        }
      },
      "required": [
        "certificate_id",
        "backend_id",
        "backend_version",
        "encoding_version",
        "obligation_id",
        "result",
        "duration_ms",
        "certificate_hash"
      ],
      "title": "VerificationCertificate",
      "type": "object"
    },
    "VerificationDecision": {
      "additionalProperties": false,
      "description": "Coordinator outcome controlling whether a state change may be applied.",
      "properties": {
        "certificates": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VerificationCertificate"
          },
          "title": "Certificates",
          "type": "array"
        },
        "obligation_id": {
          "$ref": "#/$defs/ObligationId"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/VerificationStatus"
        }
      },
      "required": [
        "obligation_id",
        "status",
        "reason"
      ],
      "title": "VerificationDecision",
      "type": "object"
    },
    "VerificationStatus": {
      "description": "Authority level assigned to one proof decision.",
      "enum": [
        "not_checked",
        "structurally_valid",
        "backend_verified",
        "cross_verified",
        "rejected",
        "inconclusive",
        "quarantined"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "$id": "urn:deductra:schema:verification-record:1",
  "additionalProperties": false,
  "description": "Public serialized verification contract for one obligation and decision.",
  "properties": {
    "decision": {
      "$ref": "#/$defs/VerificationDecision"
    },
    "obligation": {
      "$ref": "#/$defs/ProofObligation"
    }
  },
  "required": [
    "obligation",
    "decision"
  ],
  "title": "Deductra Verification Record v1",
  "type": "object"
}
